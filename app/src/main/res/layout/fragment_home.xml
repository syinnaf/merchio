<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/logo_merchio"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Merchio"
                    android:textColor="#1E40FF"
                    android:textStyle="bold"
                    android:textSize="28sp"
                    android:paddingStart="8dp"/>

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:padding="5dp"
                    android:background="@drawable/bg_icon"
                    android:src="@drawable/logo_merchio"/>
            </LinearLayout>

            <!-- SEARCH + FILTER BUTTON -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search"
                    android:hint="Searches"
                    android:paddingStart="16dp"
                    android:drawablePadding="8dp"
                    android:drawableStart="@drawable/ic_search"
                    android:textSize="14sp"/>

                <!-- Filter button wrapped in FrameLayout for badge support -->
                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="12dp">

                    <ImageButton
                        android:id="@+id/btnFilter"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_filter"
                        android:src="@drawable/ic_filter"
                        android:contentDescription="Filter"/>

                    <!-- Active filter badge (shown when filters are applied) -->
                    <View
                        android:id="@+id/viewFilterBadge"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="4dp"
                        android:background="#FF4444"
                        android:visibility="gone"/>

                </FrameLayout>
            </LinearLayout>

            <!-- ACTIVE FILTER SUMMARY (visible when filter applied) -->
            <HorizontalScrollView
                android:id="@+id/scroll_active_filters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/ll_active_filters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"/>
            </HorizontalScrollView>

            <!-- GREETING -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hello, Username !"
                android:textStyle="bold"
                android:textSize="22sp"
                android:layout_marginTop="24dp"/>

            <!-- BANNER -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/bannerViewPager"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="16dp"/>

            <!-- CATEGORY TITLE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="28dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Category"
                    android:textSize="24sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See All >"
                    android:textSize="16sp"/>
            </LinearLayout>

            <!-- CATEGORY LIST -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"/>

            <!-- POPULAR HEADER + PRODUCT COUNT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Popular"
                    android:textSize="24sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvProductCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- PRODUCT GRID -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPopular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>