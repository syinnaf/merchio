<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F2FF"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_admin_card"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingBottom="3dp"
            android:text="‹"
            android:textColor="#0D4CFF"
            android:textSize="26sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:layout_marginStart="10dp"
            android:text="Users List"
            android:textColor="@color/merchio_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="32dp"
            android:layout_height="32dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_empty_users"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:text="Belum ada user customer"
        android:textColor="@color/merchio_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_users"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1" />

</LinearLayout>
