<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_admin_popup"
    android:orientation="vertical"
    android:padding="22dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit Order Status"
        android:textColor="@color/merchio_text_primary"
        android:textSize="19sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/rg_order_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rb_status_packing"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="Packing"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/rb_status_shipping"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="Shipping"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/rb_status_delivered"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="Delivered"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/rb_status_cancelled"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="Cancelled"
            android:textSize="14sp" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_cancel_status"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_admin_button_light"
            android:gravity="center"
            android:text="Cancel"
            android:textColor="#0D4CFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_save_status"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_primary_button"
            android:gravity="center"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
