<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="112dp"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <CheckBox
            android:id="@+id/cb_item"
            android:layout_width="42dp"
            android:layout_height="match_parent"
            android:buttonTint="#111111"
            android:gravity="center" />

        <ImageView
            android:id="@+id/img_product"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:background="@drawable/bg_product_placeholder"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Product Name"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_product_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Type"
                android:textColor="#777777"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_product_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Rp0"
                android:textColor="#0647E8"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="92dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_minus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_qty_button"
                android:contentDescription="Kurangi"
                android:padding="3dp"
                android:src="@android:drawable/ic_media_previous" />

            <TextView
                android:id="@+id/tv_quantity"
                android:layout_width="26dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textColor="#111111"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/btn_plus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_qty_button"
                android:contentDescription="Tambah"
                android:padding="3dp"
                android:src="@android:drawable/ic_input_add" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@android:color/transparent"
            android:contentDescription="Hapus"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />

    </LinearLayout>

</androidx.cardview.widget.CardView>