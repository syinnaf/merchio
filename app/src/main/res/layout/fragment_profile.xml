<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="210dp">

            <ImageView
                android:id="@+id/img_header"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="@color/merchio_primary_light"
                android:scaleType="centerCrop"
                android:src="@drawable/logo_merchio" />

            <ImageView
                android:id="@+id/img_avatar"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:layout_gravity="center_horizontal|bottom"
                android:background="@drawable/bg_product_placeholder"
                android:padding="10dp"
                android:scaleType="centerCrop"
                android:src="@drawable/logo_merchio" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Name"
            android:textColor="#111111"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="@Username"
            android:textColor="#111111"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_cart_header"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:id="@+id/tv_packing_count"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="0\nPacking"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_shipping_count"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="0\nShipping"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_delivered_count"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="0\nDelivered"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/menu_purchase_history"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_profile_menu"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:text="Purchase History"
            android:textColor="#111111"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/menu_payment_method"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_profile_menu"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:text="Payment Method"
            android:textColor="#111111"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/menu_setting"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_profile_menu"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:text="Setting"
            android:textColor="#111111"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/menu_customer_service"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_profile_menu"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:text="Customer Service"
            android:textColor="#111111"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>