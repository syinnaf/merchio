<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="58dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_admin_row"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <TextView
        android:id="@+id/tv_user_number"
        android:layout_width="26dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="1"
        android:textColor="@color/merchio_text_primary"
        android:textSize="13sp" />

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="10dp"
        android:background="#DED8F1" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_user_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Naql"
            android:textColor="@color/merchio_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_user_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Status : Active"
            android:textColor="@color/merchio_text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_edit_user"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:gravity="center"
        android:text="✎"
        android:textColor="#0D4CFF"
        android:textSize="16sp" />
</LinearLayout>
